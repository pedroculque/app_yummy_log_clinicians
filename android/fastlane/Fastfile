# Android Fastlane – importa lógica compartilhada (build Flutter, symbols, supply).
# Rodar a partir da raiz do projeto: ./deploy.sh (escolhe flavor e roda iOS + Android)
# Ou só Android: cd android && fastlane dev | fastlane prod
require 'dotenv'
import('../../fastlane/GeneralFastfile')

default_platform(:android)

platform :android do
  before_all do
    ENV['FASTLANE_PLATFORM_NAME'] = 'android'
    # Sem Gemfile em android/; iOS usa bundle em ios/
    clean_project
    load_env
    increment_app_build_number
    flutter_build
  end

  lane :dev do
    uploading_firebase_distribution
  end

  lane :prod do
    # upload_crashlytics_symbols
    # upload_sentry_symbols
    upload_store
  end
end
