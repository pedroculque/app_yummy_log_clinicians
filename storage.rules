rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Paciente lê/escreve suas próprias fotos de refeições
    match /users/{userId}/meal_photos/{allPaths=**} {
      allow read: if request.auth != null
                  && request.auth.uid == userId;
      // Escrita: usuário autenticado, dono, limite 10MB, apenas imagens
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Clínico lê fotos de pacientes vinculados
    // (requer verificação via Firestore — não suportado nativamente em Storage Rules;
    //  usar signed URLs ou Cloud Functions para acesso do clínico)
  }
}
