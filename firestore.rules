rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Documento do usuário (para aparecer no console e guardar perfil).
    // Clínico pode ler users/{patientId} se o paciente estiver em clinicians/{clinicianUid}/patients.
    match /users/{userId} {
      allow read: if request.auth != null
                  && (request.auth.uid == userId
                      || exists(/databases/$(database)/documents/clinicians/$(request.auth.uid)/patients/$(userId)));
      allow write: if request.auth != null
                   && request.auth.uid == userId;
    }

    // Config do formulário de comportamento: clínico (vinculado) escreve; paciente lê.
    match /users/{patientId}/form_config/{docId} {
      allow read: if request.auth != null
                 && (request.auth.uid == patientId
                     || exists(/databases/$(database)/documents/clinicians/$(request.auth.uid)/patients/$(patientId)));
      allow write: if request.auth != null
                  && exists(/databases/$(database)/documents/clinicians/$(request.auth.uid)/patients/$(patientId));
    }

    // Paciente lê/escreve seus próprios dados (subcoleções), exceto form_config (só clínico escreve).
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId
                         && !request.path.matches('.*/form_config/.*');
    }

    // Refeições: paciente lê/escreve as próprias; clínico vinculado só lê.
    match /users/{patientId}/meals/{mealId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == patientId;
      allow read: if request.auth != null
                  && exists(/databases/$(database)/documents/clinicians/$(request.auth.uid)/patients/$(patientId));
    }

    // Conexões: paciente lê/escreve as próprias; clínico vinculado só lê.
    match /users/{patientId}/connections/{connectionId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == patientId;
      allow read: if request.auth != null
                  && exists(/databases/$(database)/documents/clinicians/$(request.auth.uid)/patients/$(patientId));
    }

    // Paciente adiciona-se à lista do clínico (create) ou remove-se (delete).
    // Precisa vir ANTES da regra genérica clinicians/{cid}/** para o paciente
    // poder escrever em clinicians/{cid}/patients/{patientId}.
    match /clinicians/{clinicianId}/patients/{patientId} {
      allow read: if request.auth != null
                  && request.auth.uid == clinicianId;
      allow create, update: if request.auth != null
                            && request.auth.uid == patientId;
      allow delete: if request.auth != null
                   && request.auth.uid == patientId;
    }

    // Clínico gerencia sua lista de pacientes (e demais subcoleções)
    match /clinicians/{clinicianId}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == clinicianId;
    }

    // Códigos de vínculo: id do doc = código que o paciente digita.
    // Leitura: qualquer usuário autenticado (paciente resolve código).
    // Escrita: apenas o clínico dono do código.
    match /clinician_codes/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
          && request.resource.data.clinicianUid == request.auth.uid;
      allow update, delete: if request.auth != null
          && resource.data.clinicianUid == request.auth.uid;
    }

  }
}
