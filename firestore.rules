// Firestore security rules — projeto Firebase: app-yummy-log-diary (partilhado com o app do paciente).
// Documentação do modelo de acesso (users/{userId} cruzado, Storage, checklist): docs/FIRESTORE_RULES.md
// Deploy: firebase deploy --project app-yummy-log-diary --only firestore:rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Documento raiz users/{userId} (perfil: photoUrl, displayName, …)
    // — Dono: read+write
    // — Paciente lê clínico: exists clinicians/{userId}/patients/{request.auth.uid}
    // — Clínico lê paciente: exists clinicians/{request.auth.uid}/patients/{userId}
    // Ver docs/FIRESTORE_RULES.md
    match /users/{userId} {
      // Dono lê/escreve tudo
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
      // Paciente vinculado pode ler perfil do clínico (foto/nome no Conectar)
      allow read: if request.auth != null
          && exists(/databases/$(database)/documents/clinicians/$(userId)/patients/$(request.auth.uid));
      // Clínico vinculado pode ler perfil do paciente (nome/foto na lista e detalhes)
      allow read: if request.auth != null
          && exists(/databases/$(database)/documents/clinicians/$(request.auth.uid)/patients/$(userId));
    }

    // Refeições: dono do usuário (substitui users/{uid}/** para meals).
    match /users/{userId}/meals/{mealId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // Vínculos: ID do documento = clinicianUid (um doc por profissional).
    // Deploy: publique o app com migração antes de publicar estas regras,
    // senão clientes antigos falham ao gravar connections.
    match /users/{userId}/connections/{connectionId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId
        || exists(/databases/$(database)/documents/clinicians/$(request.auth.uid)/patients/$(userId))
      );
      allow create: if request.auth != null && request.auth.uid == userId
          && request.resource.data.clinicianUid is string
          && request.resource.data.id is string
          && request.resource.data.clinicianUid == connectionId
          && request.resource.data.id == connectionId;
      allow update: if request.auth != null && request.auth.uid == userId
          && request.resource.data.clinicianUid is string
          && request.resource.data.id is string
          && request.resource.data.clinicianUid == connectionId
          && request.resource.data.id == connectionId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Config do formulário (ex.: comportamento na refeição em form_config/behavior).
    // Subcoleção não herda regra do doc users/{userId} — precisa de match explícito.
    match /users/{userId}/form_config/{configId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId
        || exists(/databases/$(database)/documents/clinicians/$(request.auth.uid)/patients/$(userId))
      );
      allow write: if request.auth != null && (
        request.auth.uid == userId
        || exists(/databases/$(database)/documents/clinicians/$(request.auth.uid)/patients/$(userId))
      );
    }

    // Clínico lê refeições de pacientes vinculados
    match /users/{patientId}/meals/{mealId} {
      allow read: if request.auth != null
                  && exists(/databases/$(database)/documents/clinicians/$(request.auth.uid)/patients/$(patientId));
    }

    // Paciente adiciona-se à lista do clínico (create) ou remove-se (delete).
    // Precisa vir ANTES da regra genérica clinicians/{cid}/** para o paciente
    // poder escrever em clinicians/{cid}/patients/{patientId}.
    match /clinicians/{clinicianId}/patients/{patientId} {
      allow read: if request.auth != null
                  && request.auth.uid == clinicianId;
      allow create, update: if request.auth != null
                            && request.auth.uid == patientId;
      allow delete: if request.auth != null
                   && request.auth.uid == patientId;
    }

    // Clínico gerencia sua lista de pacientes (e demais subcoleções)
    match /clinicians/{clinicianId}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == clinicianId;
    }

    // Códigos de vínculo: id do doc = código que o paciente digita.
    // Leitura: qualquer usuário autenticado (paciente resolve código).
    // Escrita: apenas o clínico dono do código.
    match /clinician_codes/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
          && request.resource.data.clinicianUid == request.auth.uid;
      allow update, delete: if request.auth != null
          && resource.data.clinicianUid == request.auth.uid;
    }

  }
}
